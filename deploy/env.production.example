EASM_WEB_HOST=127.0.0.1
EASM_WEB_PORT=18080
EASM_WEB_SESSION_SECRET=change-this-to-a-long-random-secret
EASM_WEB_SESSION_SECONDS=43200
EASM_WEB_MAX_WORKERS=1

EASM_DATA_DIR=/var/lib/cyberscan
EASM_ENV_FILE=/etc/cyberscan/cyberscan.env
EASM_WEB_USERS_FILE=/var/lib/cyberscan/web_users.json
EASM_RESULTS_DIR=/var/lib/cyberscan/results
EASM_STATE_DB=/var/lib/cyberscan/easm_state.db

VT_API_KEY=
HIBP_API_KEY=
ABUSEIPDB_API_KEY=
GSB_API_KEY=
SHODAN_API_KEY=
GITHUB_TOKEN=
EASM_WEBHOOK_URL=
